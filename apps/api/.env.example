# --- Server -----------------------------------------------------------------
NODE_ENV=development
HOST=127.0.0.1
PORT=3000
BASE_URL=http://localhost:3000
LOG_LEVEL=info

# --- Rate limiting ----------------------------------------------------------
RATE_LIMIT_PER_MIN=60

# --- Accounts ---------------------------------------------------------------
ENABLE_ACCOUNTS=true
# Boot-time defaults for the matching admin-tunable settings in the
# system_settings table. Once an admin sets a value via the admin UI,
# the DB value takes precedence on subsequent requests; the env value
# stays the boot fallback for fresh containers.
REGISTRATION_ENABLED=true
SESSION_EXPIRY_DAYS=30
DEFAULT_QUOTA_BYTES=5368709120

# --- Uploads ----------------------------------------------------------------
# Plaintext bytes per chunk in the resumable path. Default 16 MiB. On the
# S3 backend this MUST be >= 5 MiB (S3 multipart minimum part size).
CHUNK_SIZE_BYTES=16777216
# Hard server-side ceiling per single file. Acts as the non-overridable
# upper bound; the admin-tunable max_upload_size_bytes can lower it at
# runtime but never raise it past this value. Default 100 GB.
MAX_BLOB_BYTES=107374182400
# Lifetime of a pending resumable upload before the cleanup job removes
# it and frees the partial blobs. Default 24 hours.
UPLOAD_RESUME_HOURS=24

# --- Storage ----------------------------------------------------------------
STORAGE_BACKEND=filesystem
STORAGE_PATH=./data/uploads
DB_PATH=./data/shares.db

# S3 / MinIO (only when STORAGE_BACKEND=s3):
# S3_BUCKET=
# S3_ENDPOINT=
# S3_REGION=us-east-1
# S3_FORCE_PATH_STYLE=false
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Webhooks ---------------------------------------------------------------
# WEBHOOK_URL=
# WEBHOOK_SECRET=

# --- SMTP (optional) --------------------------------------------------------
# Used by the "notify on first download" feature. If SMTP_HOST is unset
# the feature is disabled silently — uploads still succeed, but the
# toggle in the UI no-ops on send. SMTP_FROM falls back to SMTP_USER
# when unset; SMTP_USER/SMTP_PASS are optional (omit both for an open
# relay or a sidecar that handles auth itself).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=ITSWEBER Send <noreply@example.com>
