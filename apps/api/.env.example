# --- Server -----------------------------------------------------------------
NODE_ENV=development
HOST=127.0.0.1
PORT=3000
BASE_URL=http://localhost:3000
LOG_LEVEL=info

# --- Limits -----------------------------------------------------------------
RATE_LIMIT_PER_MIN=60
MAX_FILE_SIZE_MB=5120
MAX_EXPIRY_HOURS=720

# --- Features ---------------------------------------------------------------
ENABLE_ACCOUNTS=true

# --- Storage ----------------------------------------------------------------
STORAGE_BACKEND=filesystem
STORAGE_PATH=./data/uploads

# Filled in M2 / M7:
# S3_ENDPOINT=
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
