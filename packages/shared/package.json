{
  "name": "@itsweber-send/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared types, validators (zod) and constants between apps/web and apps/api.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./constants": {
      "types": "./src/constants.ts",
      "import": "./dist/constants.js",
      "default": "./dist/constants.js"
    },
    "./schemas": {
      "types": "./src/schemas.ts",
      "import": "./dist/schemas.js",
      "default": "./dist/schemas.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  }
}
